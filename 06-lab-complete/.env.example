# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional: Day08 RAG multi-agent LLM endpoint.
# Nếu để trống XAH_API_KEY, app vẫn chạy bằng extractive fallback offline.
XAH_API_URL=https://api.xah.io/v1/chat/completions
XAH_API_KEY=
XAH_MODEL=vuduongcalvin/gemini-3.1-flash-lite

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
